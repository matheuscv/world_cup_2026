# Banco de Dados — PostgreSQL via Supabase (schema copa2026)
# Copie a "Direct Connection URL" ou "Connection Pooling URL" do Supabase/Render
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Porta do servidor (Render injeta automaticamente via $PORT)
PORT=8000

# Chave de administrador — protege endpoints /api/admin/*
ADMIN_KEY=troque-por-uma-chave-longa-e-aleatoria
